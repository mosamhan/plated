# Plated — environment config.
# Copy this file to `.env` and fill in real values. `.env` is gitignored — never commit keys.
# EXPO_PUBLIC_* vars are bundled into the app at build time.

# Supabase (Project Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Foursquare Places (foursquare.com/developers → your project → Service Key)
EXPO_PUBLIC_FOURSQUARE_KEY=YOUR-FOURSQUARE-SERVICE-KEY

# Google Maps SDK (console.cloud.google.com → enable "Maps SDK for iOS" /
# "Maps SDK for Android" → Credentials → create + restrict a key per platform).
# NOT EXPO_PUBLIC_-prefixed: read by app.config.ts at prebuild time only, baked
# into native Info.plist/AndroidManifest.xml — never bundled into the JS app.
GOOGLE_MAPS_IOS_API_KEY=YOUR-IOS-MAPS-API-KEY
GOOGLE_MAPS_ANDROID_API_KEY=YOUR-ANDROID-MAPS-API-KEY

# Directions API key for in-app route drawing. Called from JS at runtime, so it
# IS bundled into the app — also enable "Directions API" on this key. Can be the
# same key as above if its API restrictions include Directions API.
EXPO_PUBLIC_GOOGLE_MAPS_KEY=YOUR-MAPS-API-KEY
