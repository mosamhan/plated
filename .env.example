# Plated — environment config.
# Copy this file to `.env` and fill in real values. `.env` is gitignored — never commit keys.
# EXPO_PUBLIC_* vars are bundled into the app at build time.

# Supabase (Project Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Foursquare Places (foursquare.com/developers → your project → Service Key)
EXPO_PUBLIC_FOURSQUARE_KEY=YOUR-FOURSQUARE-SERVICE-KEY
